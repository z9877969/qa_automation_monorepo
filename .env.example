# ── MySQL ──────────────────────────────────────────────────────────────────────
# Credentials для MySQL-контейнера та підключення бекенду.
# MYSQL_USER, MYSQL_PASSWORD, MYSQL_DB передаються і в mysql-сервіс (створення
# користувача/БД), і в бекенд (підключення) — docker-compose.yml синхронізує автоматично.
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=headliner
MYSQL_PASSWORD=headliner_pass
MYSQL_DB=headliner_db

# ── Backend ────────────────────────────────────────────────────────────────────
# ⚠️  PORT, APP_DOMAIN та VITE_API_URL (frontend) — пов'язані змінні.
#     При зміні PORT оновлюйте всі три одночасно.
PORT=4040                          # порт HTTP-сервера всередині контейнера
APP_DOMAIN=http://localhost:4040   # публічна URL бекенду (для посилань на завантажені файли)

# Лише для запуску бекенду поза Docker. В Docker мережі mysql завжди доступний як mysql:3306.
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ── Frontend ───────────────────────────────────────────────────────────────────
# ⚠️  Повинна збігатись з APP_DOMAIN — фронтенд використовує цю адресу для API-запитів.
VITE_API_URL=http://localhost:4040
